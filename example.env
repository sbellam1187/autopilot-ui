# LLM configuration
LLM_PROVIDER=ollama
#use `azureopenai` for AzureOpenAI models, use 'openai' for OpenAI models, 'ollama' for local models

# OpenAI or AzureOpenAI
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-4.1
OPENAI_BASE_URL=https://models.github.ai/inference
OPENAI_API_VERSION=2024-12-01-preview
OPENAI_DEPLOYMENT_NAME=gpt-4o-classification

# Ollama
OLLAMA_MODEL=qwen3
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Reasoning Configuration
# Set to 'true' to disable thinking and reasoning steps in agent responses
# Accepted values: 'true', '1', 'yes' (case insensitive) to enable, anything else to disable
DISABLE_REASONING=false

# API configuration
REMOTE_ACTION_URL=http://agents:8000/api/chat
GRAPH_MCP_SERVER_URL=http://host.docker.internal:8002/mcp
GITHUB_MCP_SERVER_URL=http://host.docker.internal:8080/sse
AZURE_MCP_SERVER_URL=http://host.docker.internal:5008/sse
CAAS_MCP_SERVER_URL=http://host.docker.internal:8003/mcp
GRAPHQL_CLIENT_NAME=apimgmtgql

# Authentication configuration
AUTH_WELLKNOWN=https://idptest.aa.com/.well-known/openid-configuration
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Debugging
GLOBAL_DEBUG=true

# Database Configuration
# Set to 'basic' for username/password authentication
# Set to 'service_principal' for Azure service principal authentication
DB_AUTH_METHOD=basic
# Azure Service Principal Configuration (only required when DB_AUTH_METHOD=service_principal)
# These are used for Azure Database for PostgreSQL with Azure AD authentication
ARM_CLIENT_ID=your-azure-client-id
ARM_CLIENT_SECRET=your-azure-client-secret
ARM_TENANT_ID=your-azure-tenant-id
JDBC_URL=postgresql://username:password@postgres:5432/username?sslmode=disable

# RAG Configuration
VECTOR_TABLE_NAME=document_embeddings
GITHUB_TOKEN=ghp_your_github_token_here
SUPPORTED_EXTENSIONS=.md
EMBEDDING_MODEL=mxbai-embed-large
EMBEDDING_BASE_URL=http://host.docker.internal:11434
EMBEDDING_DIM=1024
EMBEDDING_API_KEY=
EMBEDDING_API_VERSION=2023-05-15
EMBEDDING_DEPLOYMENT_NAME=text-embedding-ada-002

# Ping federate config
PF_JWKS=https://idptest.aa.com/pf/JWKS
PF_ISSUER=https://idptest.aa.com
PF_AUDIENCE="APIMgmtGQL-7912682-test-TcxOY"

GH_CLIENT_ID=
GH_CLIENT_SECRET=

ENCRYPTION_SECRET_KEY=
